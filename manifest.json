{
  "manifest_version": 3,
  "name": "Diff Checker Pro",
  "version": "1.0.0",
  "description": "Professional text comparison tool with character-level diff support and history tracking",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Diff Checker Pro"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}